
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Get user document
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: Check if user has a specific role
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Helper: Check if user is blocked
    function isNotBlocked() {
      return isSignedIn() && getUserData().isBlocked == false;
    }

    match /users/{userId} {
      // Allow users to read their own profile, or admins to read any profile
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      
      // Allow users to create their own profile during signup, or admins to register new institutional users
      allow create: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      
      // Only admins can modify or delete institutional profiles
      allow update: if hasRole('admin');
      allow delete: if hasRole('admin');
    }

    match /moas/{moaId} {
      // Visibility logic: 
      // Admins/Faculty see all active records.
      // Students strictly see only approved, non-deleted records.
      allow list, get: if isSignedIn() && isNotBlocked() && (
        hasRole('admin') || 
        hasRole('faculty') || 
        (hasRole('student') && 
         resource.data.isDeleted == false && 
         resource.data.status >= 'APPROVED' && 
         resource.data.status < 'APPROVEE')
      );

      // Creation requires institutional right (Admin or authorized Faculty)
      allow create: if isSignedIn() && isNotBlocked() && (
        hasRole('admin') || 
        (hasRole('faculty') && getUserData().canAddMoa == true)
      );

      // Updating (including soft delete) requires institutional right
      allow update: if isSignedIn() && isNotBlocked() && (
        hasRole('admin') || 
        (hasRole('faculty') && getUserData().canEditMoa == true)
      );

      // Hard delete restricted to administrative purging
      allow delete: if isSignedIn() && isNotBlocked() && (
        hasRole('admin') || 
        (hasRole('faculty') && getUserData().canDeleteMoa == true)
      );
    }

    match /audit_logs/{logId} {
      allow read: if isSignedIn() && hasRole('admin');
      allow create: if isSignedIn() && isNotBlocked();
    }
  }
}
