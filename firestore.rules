rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isInstitutional() {
      return isSignedIn() && request.auth.token.email.matches('.*@neu\\.edu\\.ph$');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update, delete: if hasRole('admin');
      allow list: if hasRole('admin');
    }

    match /moas/{moaId} {
      // Institutional users can list/read approved MOAs
      // For 'list' to work, students MUST provide the corresponding filters in their query
      allow read, list: if isInstitutional() && (
        hasRole('admin') || 
        hasRole('faculty') || 
        (resource.data.isDeleted == false && resource.data.status >= 'APPROVED' && resource.data.status < 'APPROVEE')
      );

      // Maintenance restricted to Admin and Faculty
      allow create: if isInstitutional() && (hasRole('admin') || hasRole('faculty'));
      allow update: if isInstitutional() && (hasRole('admin') || hasRole('faculty'));
      
      allow delete: if false; // Use soft delete (isDeleted: true)
    }

    match /audit_logs/{logId} {
      allow read: if isSignedIn() && hasRole('admin');
    }
  }
}