
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Get user document
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: Check if user has a specific role
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Helper: Check if user is blocked
    function isNotBlocked() {
      return isSignedIn() && getUserData().isBlocked == false;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if hasRole('admin');
      allow delete: if false;
    }

    match /moas/{moaId} {
      // Students see only APPROVED active records
      allow list, get: if isSignedIn() && isNotBlocked() && (
        hasRole('admin') || 
        hasRole('faculty') || 
        (hasRole('student') && resource.data.isDeleted == false && resource.data.status >= 'APPROVED')
      );

      // Writes restricted to admin or authorized faculty
      allow create: if isSignedIn() && isNotBlocked() && (hasRole('admin') || hasRole('faculty'));
      allow update: if isSignedIn() && isNotBlocked() && (
        hasRole('admin') || 
        (hasRole('faculty') && getUserData().canEditMoa == true)
      );
      allow delete: if false; // Soft-delete only
    }

    match /audit_logs/{logId} {
      allow read: if isSignedIn() && hasRole('admin');
      allow create: if isSignedIn() && isNotBlocked();
    }
  }
}
