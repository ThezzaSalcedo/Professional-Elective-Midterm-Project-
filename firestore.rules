
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isFaculty() {
      return isSignedIn() && exists(/databases/$(database)/documents/faculty/$(request.auth.uid));
    }

    function isStudent() {
      return isSignedIn() && exists(/databases/$(database)/documents/students/$(request.auth.uid));
    }

    function getFacultyData() {
      return get(/databases/$(database)/documents/faculty/$(request.auth.uid)).data;
    }

    match /admins/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin();
    }

    match /faculty/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin();
      allow update: if isAdmin();
    }

    match /students/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin();
    }

    match /moas/{moaId} {
      allow get: if isAdmin() || isFaculty() || (isStudent() && resource.data.status.startsWith('APPROVED') && !resource.data.isSoftDeleted);
      allow list: if isAdmin() || (isFaculty() && !request.query.isSoftDeleted) || (isStudent() && request.query.status.startsWith('APPROVED') && !request.query.isSoftDeleted);
      allow create: if isAdmin() || (isFaculty() && getFacultyData().canAddMoa);
      allow update: if isAdmin() || (isFaculty() && getFacultyData().canEditMoa);
      allow delete: if isAdmin() || (isFaculty() && getFacultyData().canDeleteMoa);
    }

    match /moa_audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
