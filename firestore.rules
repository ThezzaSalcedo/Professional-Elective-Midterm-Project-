rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Check if user has an institutional email
    function isInstitutional() {
      return isSignedIn() && request.auth.token.email.matches('.*@neu\\.edu\\.ph$');
    }

    // Helper: Check if user has a specific role in the centralized 'users' collection
    function hasRole(role) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userDoc != null && userDoc.data.role == role;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if hasRole('admin');
      allow delete: if false;
    }

    match /moas/{moaId} {
      // Simplified list rules to avoid composite index requirements during development
      // We now enforce status and deletion filters in the frontend code
      allow list: if isSignedIn() && (
        hasRole('admin') || 
        hasRole('faculty') ||
        (isInstitutional() && hasRole('student'))
      );

      allow get: if isSignedIn() && (
        hasRole('admin') || 
        hasRole('faculty') || 
        (
          isInstitutional() &&
          resource.data.isDeleted == false && 
          resource.data.status >= 'APPROVED'
        )
      );

      // Writes restricted to admin or faculty
      allow create, update: if isSignedIn() && (hasRole('admin') || hasRole('faculty'));
      allow delete: if false; // Soft-delete only
    }

    match /audit_logs/{logId} {
      allow read: if isSignedIn() && hasRole('admin');
      allow create: if isSignedIn();
    }
  }
}