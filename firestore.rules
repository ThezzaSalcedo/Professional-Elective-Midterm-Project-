rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Check if user has a specific role in the centralized 'users' collection
    function hasRole(role) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if hasRole('admin');
      allow delete: if false;
    }

    match /moas/{moaId} {
      // Read/List: Allowed for Admin/Faculty. Students only if APPROVED and NOT DELETED.
      // For LIST operations, the query MUST contain filters for status and isDeleted.
      allow read, list: if isSignedIn() && (
        hasRole('admin') || 
        hasRole('faculty') || 
        (resource.data.status >= 'APPROVED' && resource.data.status < 'APPROVEE' && resource.data.isDeleted == false)
      );

      // Maintain: Admin and Faculty
      allow create: if isSignedIn() && (hasRole('admin') || hasRole('faculty'));
      allow update: if isSignedIn() && (hasRole('admin') || hasRole('faculty'));
      allow delete: if false; // Soft-delete only
    }

    match /audit_logs/{logId} {
      allow read: if isSignedIn() && hasRole('admin');
    }
  }
}