rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Check if user has a specific role in the centralized 'users' collection
    function hasRole(role) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if hasRole('admin');
      allow delete: if false;
    }

    match /moas/{moaId} {
      // Students: Can only read if MOA is APPROVED (any variant) and not deleted
      // The matches('APPROVED.*') handles 'APPROVED: Signed by President', etc.
      allow read, list: if isSignedIn() && (
        hasRole('admin') || 
        hasRole('faculty') || 
        (resource.data.status.matches('APPROVED.*') && resource.data.isDeleted == false)
      );

      // Maintenance restricted to Admin and Faculty
      allow create: if isSignedIn() && (hasRole('admin') || hasRole('faculty'));
      
      // Update: Admin/Faculty for general edits, but specific checks can be added
      allow update: if isSignedIn() && (hasRole('admin') || hasRole('faculty'));
      
      allow delete: if false; // Strict soft-delete only
    }

    match /audit_logs/{logId} {
      allow read: if isSignedIn() && hasRole('admin');
    }
  }
}