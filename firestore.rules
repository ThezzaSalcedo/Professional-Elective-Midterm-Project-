
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Check if the email belongs to the institutional domain
    function isInstitutionalEmail() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.matches('(?i).*@neu\\.edu\\.ph$');
    }

    // Helper: Get user document safely
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    // Helper: Check if user has a specific role
    function hasRole(role) {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == role;
    }

    // Helper: Check if user is blocked
    // Robust check: If profile doesn't exist yet, they aren't blocked.
    function isNotBlocked() {
      let data = getUserData();
      return isSignedIn() && (data == null || data.isBlocked == false);
    }

    match /users/{userId} {
      // Users can read and create their own profile during initial signup
      // Admins can read any profile for registry management
      allow read, create: if isSignedIn() && isInstitutionalEmail() && (request.auth.uid == userId || hasRole('admin'));
      
      // Profile modifications restricted to administrative roles
      allow update: if isSignedIn() && isInstitutionalEmail() && hasRole('admin');
      allow delete: if isSignedIn() && isInstitutionalEmail() && hasRole('admin');
    }

    match /moas/{moaId} {
      // Visibility logic: 
      // Admins/Faculty see all active records.
      // Students see only approved, non-deleted records.
      // We align the 'list' rule with the range query used in the client.
      allow list, get: if isSignedIn() && isInstitutionalEmail() && isNotBlocked() && (
        hasRole('admin') || 
        hasRole('faculty') || 
        (hasRole('student') && 
         resource.data.isDeleted == false && 
         resource.data.status >= 'APPROVED' && 
         resource.data.status < 'APPROVEE')
      );

      // Record lifecycle management restricted to authorized institutional actors
      allow create: if isSignedIn() && isInstitutionalEmail() && isNotBlocked() && (
        hasRole('admin') || 
        (hasRole('faculty') && getUserData().canAddMoa == true)
      );

      allow update: if isSignedIn() && isInstitutionalEmail() && isNotBlocked() && (
        hasRole('admin') || 
        (hasRole('faculty') && getUserData().canEditMoa == true)
      );

      allow delete: if isSignedIn() && isInstitutionalEmail() && isNotBlocked() && (
        hasRole('admin') || 
        (hasRole('faculty') && getUserData().canDeleteMoa == true)
      );
    }

    match /audit_logs/{logId} {
      // Audit logs are immutable and strictly for administrative oversight
      allow read: if isSignedIn() && isInstitutionalEmail() && hasRole('admin');
      // Allow any institutional user to create logs for audit trail purposes
      allow create: if isSignedIn() && isInstitutionalEmail() && isNotBlocked();
    }
  }
}
