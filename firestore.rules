rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isInstitutionalEmail() {
      return isSignedIn() && request.auth.token.email.matches('.*@neu\\.edu\\.ph$');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update, delete: if hasRole('admin');
      allow list: if hasRole('admin');
    }

    match /moas/{moaId} {
      // Institutional users can list/read approved MOAs
      allow read, list: if isInstitutionalEmail();

      // Maintenance restricted to Admin and Faculty
      allow create, update: if isInstitutionalEmail() && (hasRole('admin') || hasRole('faculty'));
      
      // Explicit recovery logic for Admins
      allow update: if isInstitutionalEmail() && hasRole('admin');
      
      allow delete: if false; // Use soft delete (isDeleted: true)
    }

    match /audit_logs/{logId} {
      allow read: if isSignedIn() && hasRole('admin');
    }
  }
}