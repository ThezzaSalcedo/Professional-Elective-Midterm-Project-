
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Check if the email belongs to the institutional domain
    function isInstitutionalEmail() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.matches('(?i).*@neu\\.edu\\.ph$');
    }

    // Helper: Get user document safely
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    // Helper: Check if user has a specific role
    function hasRole(role) {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == role;
    }

    // Helper: Check if user is blocked
    function isNotBlocked() {
      let data = getUserData();
      return isSignedIn() && (data == null || data.isBlocked == false);
    }

    match /users/{userId} {
      // Visibility logic:
      // 1. Own profile
      // 2. Admin
      // 3. Email-based match during handshake (allows finding pre-registered docs)
      allow read: if isSignedIn() && isInstitutionalEmail() && (
        request.auth.uid == userId || 
        hasRole('admin') || 
        resource.data.email == request.auth.token.email
      );
      
      // Allow creation during initial sign-up or handshake UID-linking
      allow create: if isSignedIn() && isInstitutionalEmail();
      
      // Profile modifications restricted to administrative roles or owner
      allow update: if isSignedIn() && isInstitutionalEmail() && (hasRole('admin') || request.auth.uid == userId);
      
      // Allow delete for admins OR for users cleaning up their own pre-registered doc during handshake
      allow delete: if isSignedIn() && isInstitutionalEmail() && (
        hasRole('admin') || 
        (resource.data.email != null && resource.data.email == request.auth.token.email)
      );
    }

    match /moas/{moaId} {
      allow list, get: if isSignedIn() && isInstitutionalEmail() && isNotBlocked() && (
        hasRole('admin') || 
        hasRole('faculty') || 
        (hasRole('student') && 
         resource.data.isDeleted == false && 
         resource.data.status >= 'APPROVED')
      );

      allow create: if isSignedIn() && isInstitutionalEmail() && isNotBlocked() && (
        hasRole('admin') || 
        (hasRole('faculty') && getUserData().canAddMoa == true)
      );

      allow update: if isSignedIn() && isInstitutionalEmail() && isNotBlocked() && (
        hasRole('admin') || 
        (hasRole('faculty') && getUserData().canEditMoa == true)
      );

      allow delete: if isSignedIn() && isInstitutionalEmail() && isNotBlocked() && (
        hasRole('admin') || 
        (hasRole('faculty') && getUserData().canDeleteMoa == true)
      );
    }

    match /audit_logs/{logId} {
      allow read: if isSignedIn() && isInstitutionalEmail() && hasRole('admin');
      allow create: if isSignedIn() && isInstitutionalEmail() && isNotBlocked();
    }
  }
}
