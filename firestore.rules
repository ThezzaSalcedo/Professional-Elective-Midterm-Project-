rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update, delete: if hasRole('admin');
      allow list: if hasRole('admin');
    }

    match /moas/{moaId} {
      // Students: Can only read if MOA is APPROVED and not deleted
      allow read: if isSignedIn() && (
        hasRole('admin') || 
        hasRole('faculty') || 
        (resource.data.status.matches('APPROVED.*') && resource.data.isDeleted == false)
      );

      // Admin & Faculty: Can maintain (Add/Edit/Soft-Delete)
      allow write: if isSignedIn() && (hasRole('admin') || hasRole('faculty'));
      
      // Admin Only: Can recover deleted MOAs
      allow update: if isSignedIn() && hasRole('admin');
    }

    // Audit Trail protection: Only Admin can read logs if split
    match /audit_logs/{logId} {
      allow read: if isSignedIn() && hasRole('admin');
    }
  }
}