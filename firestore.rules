
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update, delete: if hasRole('admin');
      allow list: if hasRole('admin');
    }

    match /moas/{moaId} {
      allow get: if isSignedIn() && (
        hasRole('admin') || 
        hasRole('faculty') || 
        (hasRole('student') && resource.data.status >= 'APPROVED' && resource.data.status < 'APPROVEE' && resource.data.isDeleted == false)
      );
      
      allow list: if isSignedIn() && (
        hasRole('admin') || 
        (hasRole('faculty') && request.query.isDeleted == false) ||
        (hasRole('student') && request.query.status >= 'APPROVED' && request.query.status < 'APPROVEE' && request.query.isDeleted == false)
      );

      allow create: if isSignedIn() && (hasRole('admin') || (hasRole('faculty') && getUserData().canAddMoa));
      allow update: if isSignedIn() && (hasRole('admin') || (hasRole('faculty') && getUserData().canEditMoa));
      allow delete: if hasRole('admin');
    }
  }
}
