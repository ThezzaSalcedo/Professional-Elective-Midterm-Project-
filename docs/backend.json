
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Centralized user profile for Admin, Faculty, and Students.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "faculty", "student"] },
        "canAddMoa": { "type": "boolean" },
        "canEditMoa": { "type": "boolean" },
        "canDeleteMoa": { "type": "boolean" },
        "isBlocked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "role"]
    },
    "Moa": {
      "title": "Moa",
      "description": "A Memorandum of Agreement record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hteId": { "type": "string" },
        "companyName": { "type": "string" },
        "address": { "type": "string" },
        "contactPerson": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "industryType": { "type": "string" },
        "effectiveDate": { "type": "string", "format": "date-time" },
        "college": { "type": "string" },
        "status": { "type": "string" },
        "isDeleted": { "type": "boolean" },
        "deletedAt": { "type": "string", "format": "date-time" },
        "auditTrail": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "operation": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "hteId", "companyName", "address", "contactPerson", "contactEmail", "industryType", "effectiveDate", "college", "status", "isDeleted", "createdAt", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Centralized repository for all system users."
    },
    "/moas/{moaId}": {
      "schema": { "$ref": "#/backend/entities/Moa" },
      "description": "Institutional partnership records."
    }
  }
}
