
{
  "entities": {
    "AdminProfile": {
      "title": "AdminProfile",
      "description": "System administrator profile with full access rights.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin"] }
      },
      "required": ["id", "email", "fullName", "role"]
    },
    "FacultyProfile": {
      "title": "FacultyProfile",
      "description": "Faculty member profile with configurable MOA permissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["Faculty"] },
        "canAddMoa": { "type": "boolean" },
        "canEditMoa": { "type": "boolean" },
        "canDeleteMoa": { "type": "boolean" }
      },
      "required": ["id", "email", "fullName", "role", "canAddMoa", "canEditMoa", "canDeleteMoa"]
    },
    "StudentProfile": {
      "title": "StudentProfile",
      "description": "Student profile with read-only access to approved MOAs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["Student"] }
      },
      "required": ["id", "email", "fullName", "role"]
    },
    "Moa": {
      "title": "Moa",
      "description": "A Memorandum of Agreement record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hteId": { "type": "string" },
        "companyName": { "type": "string" },
        "address": { "type": "string" },
        "contactPerson": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "industryType": { "type": "string" },
        "effectiveDate": { "type": "string", "format": "date-time" },
        "college": { "type": "string" },
        "status": { "type": "string" },
        "isSoftDeleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "hteId", "companyName", "address", "contactPerson", "contactEmail", "industryType", "effectiveDate", "college", "status", "isSoftDeleted", "createdAt", "updatedAt"]
    },
    "MoaAuditLog": {
      "title": "MoaAuditLog",
      "description": "Historical log of MOA modifications.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "moaId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "operationType": { "type": "string" },
        "operationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "moaId", "userId", "userName", "operationType", "operationDate"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/admins/{userId}": {
      "schema": { "$ref": "#/backend/entities/AdminProfile" },
      "description": "Collection for administrative users."
    },
    "/faculty/{userId}": {
      "schema": { "$ref": "#/backend/entities/FacultyProfile" },
      "description": "Collection for faculty users."
    },
    "/students/{userId}": {
      "schema": { "$ref": "#/backend/entities/StudentProfile" },
      "description": "Collection for student users."
    },
    "/moas/{moaId}": {
      "schema": { "$ref": "#/backend/entities/Moa" },
      "description": "Repository of institutional partnerships."
    },
    "/moa_audit_logs/{logId}": {
      "schema": { "$ref": "#/backend/entities/MoaAuditLog" },
      "description": "Audit trails for compliance tracking."
    }
  }
}
